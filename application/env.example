# ============================================================================
# Environment Configuration for Kafka Producer & Consumer
# ============================================================================
# Copy to .env and customize for your deployment.
# For Kubernetes, set these in deployment env specs instead.
# For Docker Compose, uncomment and adjust below.

# ============================================================================
# Kafka Configuration (Both Services)
# ============================================================================

# Kafka broker address (comma-separated for multiple brokers)
# Localhost for development; use Kubernetes service name for K8s
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Topic name
KAFKA_TOPIC=orders

# ============================================================================
# Producer Configuration
# ============================================================================

# Messages per second
MESSAGE_RATE_PER_SEC=10

# Batch size in bytes (larger = more throughput, higher latency)
KAFKA_PRODUCER_BATCH_SIZE=1000

# Wait time before sending batch (higher = better batching, higher latency)
KAFKA_PRODUCER_LINGER_MS=100

# Compression algorithm: snappy, gzip, lz4, zstd, none
# snappy = good balance; gzip = best ratio; lz4 = fastest
KAFKA_COMPRESSION_TYPE=snappy

# ============================================================================
# Consumer Configuration
# ============================================================================

# Consumer group ID (multiple consumers with same group_id share partitions)
KAFKA_CONSUMER_GROUP=order-processors

# Processing delay in seconds (simulates business logic: DB write, API call)
# Increase to simulate slow processing and trigger autoscaling
PROCESSING_DELAY_SECONDS=0.1

# Auto-commit offsets (false = manual commit after processing; recommended)
KAFKA_AUTO_COMMIT=false

# ============================================================================
# Logging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# HTTP Ports (for health endpoints)
# ============================================================================

# Producer health endpoint port
HTTP_PORT=8080

# Note: Consumer uses hardcoded 8081 in current implementation
# (Can be refactored to use environment variable)

# ============================================================================
# Examples
# ============================================================================

# High-throughput scenario (e.g., orders arriving at 100/sec)
# MESSAGE_RATE_PER_SEC=100
# KAFKA_PRODUCER_BATCH_SIZE=16384
# KAFKA_PRODUCER_LINGER_MS=10
# PROCESSING_DELAY_SECONDS=0.5

# Low-latency scenario (e.g., real-time fraud detection)
# MESSAGE_RATE_PER_SEC=50
# KAFKA_PRODUCER_BATCH_SIZE=100
# KAFKA_PRODUCER_LINGER_MS=5
# PROCESSING_DELAY_SECONDS=0.01

# Testing/Demo (minimal resources)
# MESSAGE_RATE_PER_SEC=1
# PROCESSING_DELAY_SECONDS=0.5
# LOG_LEVEL=DEBUG
